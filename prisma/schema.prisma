generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  EDITOR
  VIEWER
}

enum AssetStatus {
  ACTIVE
  FAULTY
  DECOMMISSIONED
}

enum TransmitterType {
  AIR
  LIQUID
}

enum SiteStatus {
  ACTIVE
  DOWN
}

enum TowerType {
  GBC
  KNET
}

enum ActivityType {
  USER_LOGIN
  USER_LOGOUT
  SITE_CREATED
  SITE_UPDATED
  SITE_STATUS_CHANGED
  SITE_TOWER_UPDATED
  SITE_HEIGHT_UPDATED
  SITE_GPS_UPDATED
  SITE_DELETED
  ASSET_CREATED
  ASSET_UPDATED
  ASSET_DELETED
  ASSET_STATUS_CHANGED
  ASSET_SERIAL_UPDATED
  INVENTORY_ITEM_CREATED
  INVENTORY_ITEM_UPDATED
  INVENTORY_ITEM_DELETED
  INVENTORY_RESTOCK_ADDED
  INVENTORY_ITEM_ISSUED
  INVENTORY_EQUIPMENT_RETURNED
  INVENTORY_LOW_STOCK
  INVENTORY_OUT_OF_STOCK
  INVENTORY_IMPORT
  SYSTEM_EVENT
  STORE_ITEM_STATUS_CHANGED
  STORE_ITEM_DELETED
}

enum StoreStatus {
  RECEIVED
  NOT_RECEIVED
}

enum InventoryItemType {
  MATERIAL
  EQUIPMENT
}

enum InventoryItemStatus {
  AVAILABLE
  LOW_STOCK
  OUT_OF_STOCK
  CHECKED_OUT
  INACTIVE
}

enum EquipmentCondition {
  NEW
  OLD
  GOOD
  FAULTY
  DAMAGED
  UNDER_REPAIR
}

enum InventoryIssueStatus {
  ISSUED
  RETURNED
}

model UserProfile {
  id        String   @id
  email     String   @unique
  fullName  String?
  role      Role     @default(VIEWER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Site {
  id              String          @id @default(cuid())
  name            String
  regMFreq        String?
  power           Int?
  transmitterType TransmitterType @default(AIR)
  status          SiteStatus      @default(ACTIVE)
  statusReason    String?
  statusChangedAt DateTime?
  towerType       TowerType       @default(GBC)
  towerHeight     Int?
  gps             String?
  locationName    String?
  
  // FUEL TRACKING FIELDS
  vrmId           String?         @unique // The 12-digit VRM Portal ID
  fuelCapacity    Int?            @default(1000) // Total tank size in liters
  fuelLevel       Float?          // Current percentage (0-100)
  lastFuelUpdate  DateTime?       // Timestamp of last API sync

  txMux1Serial    String?
  txMux2Serial    String?
  txMux3Serial    String?

  isDeleted       Boolean         @default(false)
  deletedAt       DateTime?
  deletedByEmail  String?
  deleteReason    String?

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  assets          Asset[]

  @@unique([name, isDeleted])
  @@index([isDeleted])
  @@index([deletedAt])
}

model ActivityLog {
  id          String       @id @default(cuid())
  type        ActivityType
  title       String
  details     String?
  entityType  String?
  entityId    String?
  actorEmail  String?
  createdAt   DateTime     @default(now())

  @@index([createdAt])
  @@index([type])
  @@index([actorEmail])
  @@index([entityType])
  @@index([entityId])
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subcategories Subcategory[]
  assets        Asset[]
}

model Subcategory {
  id         String   @id @default(cuid())
  name       String
  categoryId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category   Category @relation(fields: [categoryId], references: [id])
  assets     Asset[]

  @@unique([categoryId, name])
}

model Asset {
  id            String      @id @default(cuid())
  siteId        String
  categoryId    String
  subcategoryId String?
  assetName     String
  serialNumber  String?
  manufacturer  String?
  model         String?
  partNumber    String?
  status        AssetStatus @default(ACTIVE)
  specs         Json        @default("{}")
  isDeleted     Boolean     @default(false)
  deletedAt     DateTime?
  deletedByEmail String?
  deleteReason  String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  site          Site        @relation(fields: [siteId], references: [id])
  category      Category    @relation(fields: [categoryId], references: [id])
  subcategory   Subcategory? @relation(fields: [subcategoryId], references: [id])

  @@index([siteId])
  @@index([categoryId])
  @@index([serialNumber])
  @@index([isDeleted])
  @@index([deletedAt])
}

model StoreItem {
  id             String      @id @default(cuid())
  itemNo         Int
  description    String
  quantity       Int
  status         StoreStatus
  isDeleted      Boolean     @default(false)
  deletedAt      DateTime?
  deletedByEmail String?
  deleteReason   String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@unique([itemNo, isDeleted])
  @@index([status])
  @@index([itemNo])
  @@index([isDeleted])
  @@index([deletedAt])
}

model InventorySite {
  id                 String              @id @default(cuid())
  name               String
  location           String?
  description        String?
  isDeleted          Boolean             @default(false)
  deletedAt          DateTime?
  deletedByEmail     String?
  deleteReason       String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  items              InventoryItem[]
  restocks           InventoryRestock[]
  materialIssues     MaterialIssue[]
  equipmentCheckouts EquipmentCheckout[]
  issues             InventoryIssue[]

  @@unique([name, isDeleted])
  @@index([isDeleted])
  @@index([deletedAt])
}

model InventoryItem {
  id              String            @id @default(cuid())
  inventorySiteId String
  itemType        InventoryItemType
  name            String
  description     String?
  stockNumber     String?
  manufacturer    String?
  model           String?
  quantity        Int               @default(0)
  unit            String?
  reorderLevel    Int               @default(0)
  targetStockLevel Int?
  status          InventoryItemStatus @default(AVAILABLE)
  
  isDeleted       Boolean           @default(false)
  deletedAt       DateTime?
  deletedByEmail  String?
  deleteReason    String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  // NEW RELATION: Individual units/serials
  instances       AssetInstance[]

  inventorySite   InventorySite     @relation(fields: [inventorySiteId], references: [id])
  restocks        InventoryRestock[]
  materialIssues  MaterialIssue[]
  equipmentCheckouts EquipmentCheckout[]
  issues          InventoryIssue[]

  @@index([inventorySiteId])
  @@index([itemType])
  @@index([status])
  @@index([name])
  @@index([stockNumber])
  @@index([isDeleted])
  @@index([deletedAt])
}

// NEW MODEL: Deep Tracking for individual units
model AssetInstance {
  id              String              @id @default(cuid())
  inventoryItemId String
  serialNumber    String              @unique
  model           String?
  manufacturer    String?
  status          InventoryItemStatus @default(AVAILABLE)
  condition       EquipmentCondition  @default(NEW)
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  inventoryItem   InventoryItem       @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@index([inventoryItemId])
  @@index([serialNumber])
}

model InventoryRestock {
  id              String        @id @default(cuid())
  inventoryItemId String
  inventorySiteId String
  quantityAdded   Int
  dateBought      DateTime?
  dateReceived    DateTime
  supplier        String?
  receivedBy      String?
  note            String?
  createdAt       DateTime      @default(now())

  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  inventorySite   InventorySite @relation(fields: [inventorySiteId], references: [id])

  @@index([inventoryItemId])
  @@index([inventorySiteId])
  @@index([dateReceived])
}

model MaterialIssue {
  id              String        @id @default(cuid())
  inventoryItemId String
  inventorySiteId String
  requesterName   String
  requestDate     DateTime
  authorizedBy    String
  projectPurpose  String
  quantityIssued  Int
  issuedBy        String?
  remarks         String?
  createdAt       DateTime      @default(now())

  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  inventorySite   InventorySite @relation(fields: [inventorySiteId], references: [id])

  @@index([inventoryItemId])
  @@index([inventorySiteId])
  @@index([requestDate])
}

model EquipmentCheckout {
  id              String             @id @default(cuid())
  inventoryItemId String
  inventorySiteId String
  requesterName   String
  takenAt         DateTime
  returnedAt      DateTime?
  takenBy         String
  authorizedBy    String
  purpose         String
  statusBefore    EquipmentCondition
  statusAfter     EquipmentCondition?
  receivedBy      String?
  remarks         String?
  createdAt       DateTime           @default(now())

  inventoryItem   InventoryItem      @relation(fields: [inventoryItemId], references: [id])
  inventorySite   InventorySite      @relation(fields: [inventorySiteId], references: [id])

  @@index([inventoryItemId])
  @@index([inventorySiteId])
  @@index([takenAt])
  @@index([returnedAt])
}

model InventoryIssue {
  id                 String              @id @default(cuid())
  inventoryItemId    String
  inventorySiteId    String
  itemType           InventoryItemType
  quantity           Int                 @default(1)
  requesterName      String
  requesterContact   String?
  department         String?
  purpose            String
  authorizedBy       String
  issuedAt           DateTime            @default(now())
  expectedReturnDate DateTime?
  conditionAtIssue   EquipmentCondition?
  returnedBy         String?
  returnContact      String?
  returnedAt         DateTime?
  returnCondition    EquipmentCondition?
  returnNote         String?
  status             InventoryIssueStatus @default(ISSUED)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  inventoryItem      InventoryItem       @relation(fields: [inventoryItemId], references: [id])
  inventorySite      InventorySite       @relation(fields: [inventorySiteId], references: [id])

  @@index([inventoryItemId])
  @@index([inventorySiteId])
  @@index([status])
  @@index([issuedAt])
  @@index([returnedAt])
}