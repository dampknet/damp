generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  EDITOR
  VIEWER
}

enum AssetStatus {
  ACTIVE
  FAULTY
  DECOMMISSIONED
}

/**
 * Site transmitter cooling type
 */
enum TransmitterType {
  AIR
  LIQUID
}

/**
 * Site operational status
 */
enum SiteStatus {
  ACTIVE
  DOWN
}

enum TowerType {
  GBC
  KNET
}

enum ActivityType {
  SITE_STATUS_CHANGED
}

enum StoreStatus {
  RECEIVED
  NOT_RECEIVED
}

enum InventoryItemType {
  MATERIAL
  EQUIPMENT
}

enum InventoryItemStatus {
  AVAILABLE
  LOW_STOCK
  OUT_OF_STOCK
  CHECKED_OUT
  INACTIVE
}

enum EquipmentCondition {
  GOOD
  FAULTY
  DAMAGED
  UNDER_REPAIR
}

enum InventoryIssueStatus {
  ISSUED
  RETURNED
}

model UserProfile {
  id        String   @id
  email     String   @unique
  fullName  String?
  role      Role     @default(VIEWER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Site {
  id              String          @id @default(cuid())
  name            String          @unique
  regMFreq        String?
  power           Int?
  transmitterType TransmitterType @default(AIR)
  status          SiteStatus      @default(ACTIVE)
  statusReason    String?
  statusChangedAt DateTime?
  towerType       TowerType       @default(GBC)
  towerHeight     Int?
  gps             String?
  txMux1Serial    String?
  txMux2Serial    String?
  txMux3Serial    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assets Asset[]
}

model ActivityLog {
  id         String       @id @default(cuid())
  type       ActivityType
  title      String
  details    String?
  entityType String?
  entityId   String?
  actorEmail String?
  createdAt  DateTime     @default(now())

  @@index([createdAt])
  @@index([type])
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subcategories Subcategory[]
  assets        Asset[]
}

model Subcategory {
  id         String   @id @default(cuid())
  name       String
  categoryId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category Category @relation(fields: [categoryId], references: [id])
  assets   Asset[]

  @@unique([categoryId, name])
}

model Asset {
  id            String  @id @default(cuid())
  siteId        String
  categoryId    String
  subcategoryId String?

  /**
   * human readable label in UI e.g. "Amplifier 1", "Exciter 2", "Humidifier"
   */
  assetName String

  serialNumber String?
  manufacturer String?
  model        String?
  partNumber   String?
  status       AssetStatus @default(ACTIVE)

  /**
   * extra metadata (deviceType, mux group, rack component etc.)
   * { "mux": "TX_MUX_1_2" }
   */
  specs Json @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  site        Site         @relation(fields: [siteId], references: [id])
  category    Category     @relation(fields: [categoryId], references: [id])
  subcategory Subcategory? @relation(fields: [subcategoryId], references: [id])

  @@index([siteId])
  @@index([categoryId])
  @@index([serialNumber])
}

model StoreItem {
  id          String      @id @default(cuid())
  itemNo      Int         @unique
  description String
  quantity    Int
  status      StoreStatus

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([itemNo])
}

/**
 * NEW INVENTORY MODULE
 * Keep StoreItem as Central Stock.
 */

model InventorySite {
  id          String  @id @default(cuid())
  name        String  @unique
  location    String?
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items              InventoryItem[]
  restocks           InventoryRestock[]
  materialIssues     MaterialIssue[]
  equipmentCheckouts EquipmentCheckout[]
  issues             InventoryIssue[]
}

model InventoryItem {
  id              String @id @default(cuid())
  inventorySiteId String

  itemType    InventoryItemType
  name        String
  description String?

  stockNumber  String?
  manufacturer String?
  model        String?
  serialNumber String?

  quantity Int     @default(0)
  unit     String?

  reorderLevel     Int  @default(0)
  targetStockLevel Int?

  status    InventoryItemStatus @default(AVAILABLE)
  condition EquipmentCondition?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inventorySite      InventorySite       @relation(fields: [inventorySiteId], references: [id])
  restocks           InventoryRestock[]
  materialIssues     MaterialIssue[]
  equipmentCheckouts EquipmentCheckout[]
  issues             InventoryIssue[]

  @@index([inventorySiteId])
  @@index([itemType])
  @@index([status])
  @@index([name])
  @@index([stockNumber])
  @@index([serialNumber])
}

model InventoryRestock {
  id              String @id @default(cuid())
  inventoryItemId String
  inventorySiteId String

  quantityAdded Int
  dateBought    DateTime?
  dateReceived  DateTime
  supplier      String?
  receivedBy    String?
  note          String?

  createdAt DateTime @default(now())

  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])
  inventorySite InventorySite @relation(fields: [inventorySiteId], references: [id])

  @@index([inventoryItemId])
  @@index([inventorySiteId])
  @@index([dateReceived])
}

model MaterialIssue {
  id              String @id @default(cuid())
  inventoryItemId String
  inventorySiteId String

  requesterName  String
  requestDate    DateTime
  authorizedBy   String
  projectPurpose String
  quantityIssued Int
  issuedBy       String?
  remarks        String?

  createdAt DateTime @default(now())

  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])
  inventorySite InventorySite @relation(fields: [inventorySiteId], references: [id])

  @@index([inventoryItemId])
  @@index([inventorySiteId])
  @@index([requestDate])
}

model EquipmentCheckout {
  id              String @id @default(cuid())
  inventoryItemId String
  inventorySiteId String

  requesterName String
  takenAt       DateTime
  returnedAt    DateTime?

  takenBy      String
  authorizedBy String
  purpose      String

  statusBefore EquipmentCondition
  statusAfter  EquipmentCondition?

  receivedBy String?
  remarks    String?

  createdAt DateTime @default(now())

  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])
  inventorySite InventorySite @relation(fields: [inventorySiteId], references: [id])

  @@index([inventoryItemId])
  @@index([inventorySiteId])
  @@index([takenAt])
  @@index([returnedAt])
}

model InventoryIssue {
  id              String               @id @default(cuid())
  inventoryItemId String
  inventorySiteId String

  itemType InventoryItemType
  quantity Int                  @default(1)

  requesterName    String
  requesterContact String?
  department       String?

  purpose String

  authorizedBy String

  issuedAt           DateTime @default(now())
  expectedReturnDate DateTime?

  conditionAtIssue EquipmentCondition?

  returnedBy      String?
  returnContact   String?
  returnedAt      DateTime?
  returnCondition EquipmentCondition?
  returnNote      String?

  status InventoryIssueStatus @default(ISSUED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])
  inventorySite InventorySite @relation(fields: [inventorySiteId], references: [id])

  @@index([inventoryItemId])
  @@index([inventorySiteId])
  @@index([status])
  @@index([issuedAt])
  @@index([returnedAt])
}